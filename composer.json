{
    "name": "interdotz/sdk-php",
    "description": "Official PHP SDK for Interdotz ecosystem",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "Interdotz\\Sdk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Interdotz\\Sdk\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
